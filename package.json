{
  "name": "rizqhub",
  "version": "3.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "config:check": "node scripts/validate-env.mjs",
    "baseline:check": "node scripts/verify-baseline.mjs",
    "migrations:check": "node scripts/validate-migration-files.mjs",
    "migrations:test": "node scripts/validate-migrations.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/*.test.ts",
    "verify:static": "npm run migrations:check && npm test && npm run lint && npm run typecheck",
    "verify": "npm run verify:static && npm run build",
    "ops:storage-manifest": "node scripts/storage-manifest.mjs",
    "ops:backup": "node scripts/backup.mjs",
    "ops:backup:verify": "node scripts/verify-backup.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx scripts/seed.ts",
    "workspace:backfill": "tsx scripts/backfill-workspaces.ts",
    "workspace:reconcile": "tsx scripts/reconcile-workspaces.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.25.0",
    "next": "16.2.10",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5"
  }
}
